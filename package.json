{
  "name": "ecommerce-eurostar",
  "version": "1.0.0",
  "description": "In-memory e-commerce REST API with JWT auth and checkout rules",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "test": "npm run test:pathCoverage",
    "test:pathCoverage": "mocha \"test/pathCoverage/**/*.spec.js\" --reporter mochawesome --reporter-options reportDir=test/reports/pathCoverage,reportFilename=mochawesome-report,overwrite=true,html=true,json=true"
  },
  "keywords": [
    "express",
    "jwt",
    "ecommerce",
    "rest-api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "mochawesome": "^7.1.4",
    "supertest": "^7.2.2"
  }
}
